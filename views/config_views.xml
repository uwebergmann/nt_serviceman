<odoo>
    <record id="view_nt_serviceman_config_form" model="ir.ui.view">
        <field name="name">nt_serviceman.config.form</field>
        <field name="model">nt_serviceman.config</field>
        <field name="arch" type="xml">
            <form string="Einstellungen NT:ServiceMan">
                <sheet>
                    <group string="NetBox-Anbindung" col="2">
                        <group>
                            <field name="netbox_base_url" placeholder="https://netbox.example.com"/>
                            <field name="netbox_api_token" password="True" placeholder="API-Token aus NetBox: My Account → API Tokens"/>
                            <div class="d-flex align-items-start gap-2" style="flex-wrap: wrap;">
                                <button name="action_test_netbox_url" type="object"
                                        string="Test URL" class="btn-primary flex-shrink-0"/>
                                <field name="netbox_test_result" nolabel="1" placeholder="Klicken Sie auf 'Test URL', um die Verbindung zu prüfen."
                                       class="flex-grow-1" style="min-width: 15em; white-space: pre-wrap;"/>
                            </div>
                        </group>
                    </group>
                    <group string="NetBox-Synchronisation" col="4" class="mt16">
                        <group col="1">
                            <button name="action_fetch_device_roles_from_netbox" type="object"
                                    string="Hole Device Roles" class="btn btn-primary"/>
                        </group>
                        <group col="3">
                            <p class="text-muted mb-0" style="min-width: 20em;">
                                Lädt alle Device Roles aus NetBox und aktualisiert die bestehende Liste.
                                Bestehende Zuordnungen zu CI-Klassen bleiben unverändert erhalten.
                            </p>
                        </group>
                        <group col="1">
                            <button name="action_sync_all_cis_from_netbox" type="object"
                                    string="Alle CI holen" class="btn btn-secondary"/>
                            <button name="action_sync_all_cis_full_from_netbox" type="object"
                                    string="Vollabgleich" class="btn btn-outline-secondary"/>
                        </group>
                        <group col="3">
                            <p class="text-muted mb-0" style="min-width: 20em;">
                                Holt alle Geräte von NetBox. Neue anlegen, bestehende aktualisieren,
                                entfernte archivieren (nie löschen). „Alle CI holen“ nutzt Inkremental-Sync (nur Änderungen); „Vollabgleich“ holt alles und erkennt Archivierung.
                            </p>
                        </group>
                        <group col="1">
                            <button name="action_refresh_netbox_device_fields" type="object"
                                    string="CI-Felder holen" class="btn btn-primary"/>
                        </group>
                        <group col="3">
                            <p class="text-muted mb-0" style="min-width: 20em;">
                                Lädt alle Gerätefelder aus dem NetBox-Schema und stellt sie als Auswahlliste
                                in den Leistungen bereit. So legen Sie fest, welche NetBox-Felder für eine Leistung
                                ausgefüllt sein müssen.
                            </p>
                        </group>
                    </group>
                    <group string="Letzter Vollabgleich" col="2" class="mt16">
                        <group>
                            <field name="last_full_sync_at" readonly="1"/>
                            <field name="last_full_sync_state" readonly="1"/>
                        </group>
                        <group>
                            <field name="last_full_sync_error" readonly="1"
                                   attrs="{'invisible': [('last_full_sync_state', '!=', 'failed')]}"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"
                           groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_nt_serviceman_config" model="ir.actions.act_window">
        <field name="name">Einstellungen NT:ServiceMan</field>
        <field name="res_model">nt_serviceman.config</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
    </record>

    <record id="action_nt_serviceman_config_server" model="ir.actions.server">
        <field name="name">Einstellungen öffnen</field>
        <field name="model_id" ref="model_nt_serviceman_config"/>
        <field name="state">code</field>
        <field name="code">
config = model.search([], limit=1)
if not config:
    config = model.create({})
action = {
    'type': 'ir.actions.act_window',
    'name': 'Einstellungen NT:ServiceMan',
    'res_model': 'nt_serviceman.config',
    'res_id': config.id,
    'view_mode': 'form',
    'target': 'inline',
}
        </field>
    </record>

    <menuitem id="menu_nt_serviceman_config_settings"
              name="Einstellungen"
              parent="menu_nt_serviceman_config"
              action="action_nt_serviceman_config_server"
              sequence="10"
              groups="nt_serviceman.group_nt_serviceman_admin"/>
</odoo>
