<odoo>
    <record id="view_contract_recurrent_form_cmdb_ci" model="ir.ui.view">
        <field name="name">contract.recurrent.form.cmdb.ci</field>
        <field name="model">contract.recurrent</field>
        <field name="inherit_id" ref="intero_net.view_contract_recurrent_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <xpath expr="//page[.//field[@name='cmdb_ids']]" position="replace">
                <page string="CMDB" attrs="{'invisible': [('state', '=', 'sale')]}">
                    <group>
                        <button name="action_assign_configuration_items" type="object"
                                string="CI zuordnen"
                                class="btn-primary"/>
                    </group>
                    <field name="configuration_item_ids" colspan="4" nolabel="1">
                        <tree string="" create="false" delete="false" editable="bottom"
                              decoration-success="service_fields_status == 'ok'"
                              decoration-warning="service_fields_status == 'warning'">
                            <field name="service_fields_status" column_invisible="1"/>
                            <field name="service_fields_status_icon" string=""/>
                            <field name="cmdb_id"/>
                            <field name="name"/>
                            <field name="ci_class_id"/>
                            <field name="netbox_role_id"/>
                            <field name="netbox_display_url" string="NetBox" widget="url"/>
                            <button name="action_open_form" type="object"
                                    string="→ Formular" icon="fa-arrow-right" class="btn-link"
                                    title="CI im Formular öffnen"/>
                            <button name="action_unassign_contract" type="object"
                                    string="Entfernen" icon="fa-times" class="btn-link"
                                    title="CI aus Vertrag entfernen"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Leistungsmatrix-Tab (Kap. 11.2) -->
    <record id="view_contract_recurrent_form_matrix" model="ir.ui.view">
        <field name="name">contract.recurrent.form.matrix</field>
        <field name="model">contract.recurrent</field>
        <field name="inherit_id" ref="intero_net.view_contract_recurrent_form"/>
        <field name="priority">51</field>
        <field name="arch" type="xml">
            <xpath expr="//page[.//field[@name='configuration_item_ids']]" position="after">
                <page string="Leistungsmatrix" name="ci_class_matrix">
                    <group>
                        <field name="ci_class_matrix_has_archived" invisible="1"/>
                        <button name="action_init_ci_class_matrix_lines" type="object"
                                string="Fehlende Zeilen hinzufügen"
                                class="btn-secondary"
                                help="Ergänzt Zeilen für neu angelegte CI-Klassen (bei Vertragserstellung werden alle automatisch angelegt)."/>
                        <field name="ci_class_matrix_archived_banner" colspan="4" nolabel="1"
                               attrs="{'invisible': [('ci_class_matrix_has_archived', '=', False)]}"/>
                    </group>
                    <field name="ci_class_matrix_line_ids" colspan="4" nolabel="1">
                        <tree string="Leistungsmatrix" create="false" delete="true" editable="bottom"
                              decoration-muted="has_archived_services">
                            <field name="ci_class_id"/>
                            <field name="quantity"/>
                            <field name="actual_quantity"/>
                            <field name="quantity_deviation"/>
                            <field name="service_ids" widget="many2many_tags"
                                   options="{'no_create': True, 'color_field': 'color'}"
                                   context="{'active_test': False}"/>
                            <field name="has_archived_services" invisible="1"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Filter und Gruppierung „Vertragsabweichung" in Vertragsliste -->
    <record id="view_contract_recurrent_search_nt_serviceman" model="ir.ui.view">
        <field name="name">contract.recurrent.search.nt_serviceman</field>
        <field name="model">contract.recurrent</field>
        <field name="inherit_id" ref="intero_net.view_account_analytic_account_service_search"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='filter_substitution_not_done']" position="after">
                <filter name="filter_vertragsabweichung" string="Mit Vertragsabweichung"
                        domain="[('vertragsabweichung', '=', True)]"/>
            </xpath>
            <xpath expr="//filter[@name='group_status']" position="before">
                <filter name="group_vertragsabweichung" string="Vertragsabweichung" domain="[]"
                        context="{'group_by': 'vertragsabweichung'}"/>
            </xpath>
        </field>
    </record>
</odoo>
