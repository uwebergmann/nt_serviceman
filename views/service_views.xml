<odoo>
    <record id="view_service_search" model="ir.ui.view">
        <field name="name">nt_serviceman.service.search</field>
        <field name="model">nt_serviceman.service</field>
        <field name="arch" type="xml">
            <search string="Leistungen">
                <field name="code"/>
                <field name="name"/>
                <filter name="filter_archived" string="Archivierte einblenden"
                        domain="[]" context="{'active_test': False}"/>
            </search>
        </field>
    </record>

    <record id="view_service_tree" model="ir.ui.view">
        <field name="name">nt_serviceman.service.tree</field>
        <field name="model">nt_serviceman.service</field>
        <field name="arch" type="xml">
            <tree string="Leistungen" decoration-muted="not active" editable="bottom"
                  delete="false">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
                <button name="action_open_form" type="object" icon="fa-arrow-right"
                        title="Formular öffnen" string="→ Formular" class="btn btn-link"/>
            </tree>
        </field>
    </record>

    <record id="view_service_form" model="ir.ui.view">
        <field name="name">nt_serviceman.service.form</field>
        <field name="model">nt_serviceman.service</field>
        <field name="arch" type="xml">
            <form string="Leistung">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Beschreibung" col="1">
                        <field name="description" nolabel="1" placeholder="Ausführliche Beschreibung der Leistung."/>
                    </group>
                    <group string="Verfügbar für CI-Klassen" col="1">
                        <field name="ci_class_ids" nolabel="1"
                               options="{'no_create': True}"/>
                    </group>
                    <group string="NetBox-Device-Felder (Häkchen = erforderlich)" col="1">
                        <field name="required_device_field_ids" nolabel="1"
                               help="Häkchen = dieses Feld muss am CI ausgefüllt sein. Keine Einträge? Unter Konfiguration den Button „Device-Felder aus Schema laden“ ausführen.">
                            <tree string="Device-Felder" editable="bottom" delete="false" create="false">
                                <field name="is_required" string="Erforderlich"/>
                                <field name="field_path" readonly="1"/>
                                <field name="example_value" readonly="1"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"
                           groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_service" model="ir.actions.act_window">
        <field name="name">Leistungen</field>
        <field name="res_model">nt_serviceman.service</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_service_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Leistungen definieren die Dienstleistungen, die NETHINKS grundsätzlich erbringen kann.
            </p>
            <p>
                Die Liste wird bei Installation mit sieben Standard-Leistungen vorgefüllt
                und kann frei ergänzt oder angepasst werden.
            </p>
        </field>
    </record>

    <menuitem id="menu_service"
              name="Leistungen"
              parent="menu_nt_serviceman_config"
              action="action_service"
              sequence="15"
              groups="nt_serviceman.group_nt_serviceman_admin"/>
</odoo>
